DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_TIME_ZONE=Asia/Tokyo
# Leave DATABASE_URL commented to use local sqlite db.sqlite3
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/release_synchronizer

ADO_ORGANIZATION=
ADO_PROJECT=
ADO_PAT=
ADO_SYNC_INTERVAL_SECONDS=300
ADO_WORK_ITEM_TYPES=User Story,Product Backlog Item

DEMO_PUBLIC_MODE=True
SITE_BASE_URL=http://127.0.0.1:8000
DEFAULT_FROM_EMAIL=noreply@release-synchronizer.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
